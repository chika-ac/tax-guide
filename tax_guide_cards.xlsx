<!DOCTYPE html>
<!--
  ================================================================
  ファイル名    : tax_guide.html
  役割         : 所得税・住民税 控除ガイド（コールセンター職員向け参照ツール）
  最終更新日    : 2025-12-01
  担当         : （担当者名・連絡先をここに記入）
  ================================================================
  【依存関係】
    外部CDN  : なし（完全オフライン動作）
    フォント : システムフォント（OS付属）
    画像     : なし
  ================================================================
  【ファイル内ゾーン構成】
    [ZONE 1] CSSゾーン      : <style> ～ </style>        ← 変更禁止
    [ZONE 2] データゾーン   : ★★★ここだけ編集★★★       ← ここを編集
    [ZONE 3] ロジック/DOM   : ここより下は編集不要        ← 変更禁止
  ================================================================
  【変更頻度が高い箇所（クイックリファレンス）】
    日付更新   → DATA_UPDATED 変数（データゾーン先頭）
    控除内容更新 → DEDUCTIONS 配列（データゾーン）
    年齢判定年  → judgeYear 定数（calcAge 関数内）※要注意
  ================================================================
  詳細は README.md を参照してください。
-->
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>所得税・住民税 控除ガイド（令和7年改正対応）</title>
<style>
/*
  ================================================================
  CSSゾーン（変更禁止）
  ─────────────────────────────────
  CSS変数（:root）
    --bg/--bg2/--bg3       : 背景色3段階（ライトモード）
    --text/--text2/--text3 : テキスト色3段階
    --info/--success/--warning/--danger/--purple/--amber
      各カードバッジ・タグ・状態表示に使用（-bg/-text/-border）
    --radius/--radius-lg   : 角丸サイズ（8px / 12px）
  ダークモード: @media(prefers-color-scheme:dark) で全変数を上書き
  ================================================================
*/
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg:#ffffff; --bg2:#f5f4f0; --bg3:#eeece7;
  --text:#1a1a18; --text2:#5f5e5a; --text3:#888780;
  --border:rgba(0,0,0,0.12); --border2:rgba(0,0,0,0.20);
  --info-bg:#e6f1fb; --info-text:#0c447c; --info-border:#378add;
  --success-bg:#eaf3de; --success-text:#27500a; --success-border:#639922;
  --warning-bg:#faeeda; --warning-text:#633806; --warning-border:#ba7517;
  --danger-bg:#fcebeb; --danger-text:#791f1f; --danger-border:#e24b4a;
  --purple-bg:#EEEDFE; --purple-text:#3C3489;
  --amber-bg:#faeeda; --amber-text:#633806;
  --radius:8px; --radius-lg:12px;
}
@media (prefers-color-scheme:dark) {
  :root {
    --bg:#1e1e1c; --bg2:#2a2a28; --bg3:#333330;
    --text:#e8e6de; --text2:#a8a69e; --text3:#6e6c66;
    --border:rgba(255,255,255,0.12); --border2:rgba(255,255,255,0.22);
    --info-bg:#0c2d4a; --info-text:#85b7eb; --info-border:#185fa5;
    --success-bg:#173404; --success-text:#97c459; --success-border:#3b6d11;
    --warning-bg:#2a1c08; --warning-text:#ef9f27; --warning-border:#854f0b;
    --danger-bg:#2e1010; --danger-text:#f09595; --danger-border:#a32d2d;
    --purple-bg:#26215C; --purple-text:#CECBF6;
    --amber-bg:#2a1c08; --amber-text:#ef9f27;
  }
}
body { font-family:-apple-system,BlinkMacSystemFont,"Hiragino Sans","Hiragino Kaku Gothic ProN","Noto Sans JP",sans-serif; font-size:14px; background:var(--bg3); color:var(--text); min-height:100vh; line-height:1.6; }
.page-header { background:var(--bg); border-bottom:0.5px solid var(--border); padding:12px 24px; display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
.page-header h1 { font-size:15px; font-weight:500; }
.rev-tag { font-size:11px; font-weight:500; background:var(--warning-bg); color:var(--warning-text); border-radius:var(--radius); padding:2px 8px; }
.upd-tag { font-size:11px; color:var(--text3); margin-left:auto; }
.layout { display:flex; min-height:calc(100vh - 45px); }
.sidebar { width:300px; flex-shrink:0; background:var(--bg); border-right:0.5px solid var(--border); padding:16px 14px; overflow-y:auto; position:sticky; top:0; max-height:calc(100vh - 45px); }
.main { flex:1; padding:16px 20px; min-width:0; }
.sec { margin-bottom:16px; }
.sec-label { font-size:11px; font-weight:500; color:var(--text2); letter-spacing:0.04em; margin-bottom:7px; display:flex; align-items:center; gap:6px; }
.divider { border:none; border-top:0.5px solid var(--border); margin:14px 0; }
.chips { display:flex; flex-wrap:wrap; gap:5px; }
.chip { padding:5px 11px; border:0.5px solid var(--border2); border-radius:99px; font-size:12px; cursor:pointer; background:transparent; color:var(--text2); transition:all .12s; }
.chip:hover { background:var(--bg2); }
.chip.sel { background:var(--info-bg); color:var(--info-text); border-color:var(--info-border); font-weight:500; }
.chip.dim { opacity:0.3; pointer-events:none; }
.inc-block { border:0.5px solid var(--border); border-radius:var(--radius-lg); padding:10px 12px; background:var(--bg); margin-bottom:7px; }
.inc-head { display:flex; align-items:center; gap:8px; margin-bottom:8px; }
.inc-row { display:flex; align-items:center; gap:7px; margin-bottom:5px; }
.inc-row:last-child { margin-bottom:0; }
.inc-row label { font-size:11px; color:var(--text2); min-width:86px; }
.inc-row input[type=number] { width:90px; padding:4px 7px; border:0.5px solid var(--border2); border-radius:var(--radius); font-size:13px; background:var(--bg); color:var(--text); }
.inc-row .unit { font-size:11px; color:var(--text2); }
.inc-hint { font-size:10px; color:var(--text3); margin-top:3px; }
.inc-result { font-size:11px; color:var(--text2); margin-top:6px; padding-top:6px; border-top:0.5px solid var(--border); }
.inc-result span { font-weight:500; color:var(--text); }
select { font-size:12px; border:0.5px solid var(--border2); border-radius:var(--radius); padding:4px 7px; background:var(--bg); color:var(--text); cursor:pointer; }
.add-btn { width:100%; padding:6px 0; border:0.5px dashed var(--border2); border-radius:var(--radius); font-size:12px; cursor:pointer; background:transparent; color:var(--text2); text-align:center; transition:all .12s; margin-top:4px; }
.add-btn:hover { background:var(--bg2); }
.total-box { margin-top:8px; padding:8px 12px; background:var(--bg2); border-radius:var(--radius); font-size:11px; }
.total-label { color:var(--text2); }
.total-val { font-size:13px; font-weight:500; color:var(--text); margin-top:2px; }
.total-val.ok { color:var(--success-text); }
.total-val.ng { color:var(--danger-text); }
.clear-btn { font-size:10px; color:var(--text2); background:none; border:0.5px solid var(--border2); border-radius:var(--radius); padding:2px 7px; cursor:pointer; }
.clear-btn:hover { background:var(--bg2); }
.remove-btn { font-size:10px; color:var(--danger-text); background:none; border:0.5px solid var(--danger-border); border-radius:var(--radius); padding:2px 7px; cursor:pointer; }
.remove-btn:hover { background:var(--danger-bg); }
.self-note { font-size:10px; margin-top:3px; color:var(--text3); }

/* 年齢計算ツール */
.age-tool { background:var(--bg2); border-radius:var(--radius-lg); padding:10px 12px; }
.age-row { display:flex; align-items:center; gap:7px; margin-bottom:5px; }
.age-row label { font-size:11px; color:var(--text2); min-width:50px; }
.age-row input[type=date] { flex:1; padding:4px 7px; border:0.5px solid var(--border2); border-radius:var(--radius); font-size:12px; background:var(--bg); color:var(--text); }
.age-result { font-size:11px; color:var(--text2); margin-top:6px; padding-top:6px; border-top:0.5px solid var(--border); line-height:1.7; }
.age-result strong { font-weight:500; color:var(--text); }
.age-note { font-size:10px; color:var(--text3); margin-top:4px; line-height:1.5; }

/* メインエリア */
.results-heading { font-size:11px; font-weight:500; color:var(--text2); margin-bottom:5px; }
.result-count { font-size:12px; color:var(--text2); margin-bottom:10px; }
.guide { font-size:13px; color:var(--text2); text-align:center; padding:32px 0; }
.empty { text-align:center; padding:32px 0; font-size:13px; color:var(--text2); }

/* 結果カード */
.card { background:var(--bg); border:0.5px solid var(--border); border-radius:var(--radius-lg); padding:12px 14px; margin-bottom:9px; cursor:pointer; transition:border-color .15s; }
.card:hover { border-color:var(--border2); }
.card.open { border-color:var(--info-border); }
.card-head { display:flex; align-items:flex-start; gap:9px; }
.badge { flex-shrink:0; font-size:10px; font-weight:500; padding:2px 7px; border-radius:var(--radius); white-space:nowrap; }
.b-blue   { background:var(--info-bg);    color:var(--info-text); }
.b-green  { background:var(--success-bg); color:var(--success-text); }
.b-amber  { background:var(--amber-bg);   color:var(--amber-text); }
.b-red    { background:var(--danger-bg);  color:var(--danger-text); }
.b-purple { background:var(--purple-bg);  color:var(--purple-text); }
.card-summary { flex:1; min-width:0; }
.card-title { font-size:13px; font-weight:500; color:var(--text); margin-bottom:1px; }
.new-tag { font-size:10px; font-weight:500; background:var(--purple-bg); color:var(--purple-text); border-radius:4px; padding:1px 5px; margin-left:5px; vertical-align:middle; }
/* 常時表示エリア */
.card-visible { margin-top:4px; display:flex; flex-wrap:wrap; gap:5px; align-items:center; }
.cv-pill { font-size:11px; background:var(--bg2); color:var(--text2); border-radius:99px; padding:2px 8px; white-space:nowrap; }
.cv-amount { font-size:13px; font-weight:500; color:var(--success-text); }
.cv-warn { font-size:11px; color:var(--warning-text); }
.chevron { margin-left:auto; flex-shrink:0; font-size:10px; color:var(--text3); transition:transform .2s; padding-top:2px; }
.card.open .chevron { transform:rotate(180deg); }
/* 詳細エリア */
.detail { display:none; margin-top:10px; padding-top:10px; border-top:0.5px solid var(--border); }
.card.open .detail { display:block; }
.cond-row { display:flex; gap:7px; margin-bottom:5px; font-size:12px; }
.cond-lbl { flex-shrink:0; width:74px; font-size:10px; font-weight:500; color:var(--text2); padding-top:1px; }
.cond-val { color:var(--text); line-height:1.5; }
.cond-sub { font-size:10px; color:var(--text2); margin-top:1px; }
.amt-box { margin-top:8px; background:var(--bg2); border-radius:var(--radius); padding:8px 10px; }
.amt-title { font-size:10px; font-weight:500; color:var(--text2); margin-bottom:5px; }
.amt-table { width:100%; font-size:11px; border-collapse:collapse; }
.amt-table th { text-align:left; font-weight:400; color:var(--text2); padding:2px 7px 2px 0; vertical-align:top; }
.amt-table td { font-weight:500; color:var(--text); padding:2px 0; vertical-align:top; white-space:nowrap; }
.note { font-size:10px; color:var(--text2); margin-top:7px; line-height:1.6; }
.note b { font-weight:500; color:var(--text); }
.note-ok  { color:var(--success-text); }
.note-ng  { color:var(--danger-text); }

@media (max-width:680px) {
  .layout { flex-direction:column; }
  .sidebar { width:100%; max-height:none; position:static; border-right:none; border-bottom:0.5px solid var(--border); }
  .main { padding:14px; }
  .upd-tag { display:none; }
}
</style>
</head>
<body>

<!-- ★★★ ここだけ編集してください ★★★ -->
<script>
/*
  ================================================================
  データゾーン（★編集可能エリア）
  ================================================================
  【編集方法】
  " " の中の文字・数字を書き換えて保存→ブラウザリロードで反映。
  行末のカンマ , は消さないでください。
  DATA_UPDATED の日付を更新すると画面右上に反映されます。

  【DEDUCTIONSオブジェクトの主なフィールド】
  id          : 一意キー（JS参照用。変更不可）
  sortIncome  : 表示順（収入要件の上限・万円）。小さいほど上位表示
  badge       : バッジ色クラス（b-blue/b-green/b-amber/b-red/b-purple）
  section     : "self" = 本人の状況。未指定 = 家族の状況
  matchRule   : 表示条件オブジェクト
    rel/relNot   : 続柄チップの一致/不一致
    ageIn        : 年齢チップの値（配列）
    incomeMax/Min: 家族の合計所得の上限/下限（万円）
    special      : famSpecialセットのキー
    specialNot   : famSpecialセットの除外キー（配列）
    selfSpecial  : selfSpecialセットのキー
  note        :
    ⚠️ 始まり → タイトル横「⚠️ 要年末調整申告」タグを自動表示
    ✅ 始まり → タイトル横「✅ 申告不要」タグを自動表示
  ================================================================
*/

const DATA_UPDATED = "2026-03-27（令和7年12月施行 改正対応）";

const DEDUCTIONS = [

  /* ---- 年少扶養親族（住民税の非課税判定） ----*/
  {
    id:"dep_minor", sortIncome:0, badge:"b-green", badgeText:"年少扶養",
    title:"年少扶養親族（住民税の非課税判定）",
    amountShort:"扶養控除なし",
    incomeReq:"要件：住民税非課税の人数カウントのみ",
    matchRule:{ relNot:"spouse", ageIn:["u16"] },
    conditions:[
      { l:"対象", v:"15歳以下（12月31日時点）の扶養親族" },
      { l:"所得税", v:"扶養控除の対象外（児童手当が別途支給されるため）" },
      { l:"住民税", v:"扶養控除の対象外だが、非課税限度額の人数にカウントされる", s:"非課税限度額 ＝ 35万円×（本人＋同一生計配偶者＋扶養親族数）＋10万円＋21万円" },
      { l:"申告方法", v:"年末調整の「住民税に関する事項」欄に氏名を記載（記載漏れ注意）" },
    ],
    amounts:[
      { c:"所得税の扶養控除", a:"なし" },
      { c:"住民税の扶養控除", a:"なし" },
      { c:"住民税の非課税判定", a:"子ども1人につき35万円分、非課税上限が拡大" },
    ],
    note:"⚠️【記載欄注意】年末調整の「住民税に関する事項」欄への記載（所得税の扶養控除欄ではない）。記載欄を間違えると住民税の非課税判定に反映されません。夫婦共働きの場合、所得の少ない方の扶養に入れると住民税が非課税になるケースあり。同一の子を夫婦双方が申告することは不可。障害がある場合は別途「障害者控除」の対象になる場合あり。",
  },

  /* ---- 配偶者控除 ----*/
  {
    id:"spouse_ctrl", sortIncome:123, badge:"b-blue", badgeText:"配偶者",
    title:"配偶者控除",
    amountShort:"控除額：38万円（住民税33万円）〜最大48万円（配偶者70歳以上）",
    incomeReq:"要件：配偶者の所得58万円以下（給与収入のみ：123万円以下）　※源泉徴収計算は所得95万円以下が対象",
    matchRule:{ rel:"spouse", incomeMax:58 },
    conditions:[
      { l:"対象", v:"法律上の婚姻関係がある配偶者（内縁不可）" },
      { l:"配偶者の収入", v:"合計所得 58万円以下", s:"給与収入のみ：123万円以下（旧103万円）" },
      { l:"生計", v:"納税者と生計を一にしていること" },
    ],
    amounts:[
      { c:"配偶者70歳未満・納税者所得≦900万", a:"38万円（住民税33万円）" },
      { c:"配偶者70歳未満・納税者所得900万超〜950万", a:"26万円（住民税22万円）" },
      { c:"配偶者70歳未満・納税者所得950万超〜1,000万", a:"13万円（住民税11万円）" },
      { c:"配偶者70歳以上（老人控除対象配偶者）・納税者所得≦900万", a:"48万円（住民税38万円）" },
      { c:"配偶者70歳以上・納税者所得900万超〜950万", a:"32万円（住民税26万円）" },
      { c:"配偶者70歳以上・納税者所得950万超〜1,000万", a:"16万円（住民税13万円）" },
      { c:"納税者所得1,000万超", a:"適用なし" },
    ],
    note:"⚠️【源泉徴収との関係】配偶者の所得58万円超〜95万円以下の場合、毎月の源泉徴収計算には反映されますが、年末調整での控除区分は配偶者特別控除として精算されます。令和7年改正で123万円の壁に引き上げ（旧103万円）。住民税への反映は令和8年度分（2026年6月以降）から。【併用可能①】配偶者と死別し再婚していない場合に限り、ひとり親控除と同時に受けられる（死別限定）。【併用可能②】配偶者が障害者の場合は障害者控除も受けられる。",
  },

  /* ---- 配偶者特別控除 ----*/
  {
    id:"spouse_special", sortIncome:201, badge:"b-blue", badgeText:"配偶者",
    title:"配偶者特別控除",
    amountShort:"控除額：最大38万円（住民税33万円）",
    incomeReq:"要件：配偶者の所得58万円超〜133万円以下（給与収入のみ：123万円超〜201万5,999円以下）　※源泉徴収計算は所得95万円以下の場合のみ反映",
    matchRule:{ rel:"spouse", incomeMin:58, incomeMax:133 },
    conditions:[
      { l:"対象", v:"法律上の婚姻関係がある配偶者" },
      { l:"配偶者の収入", v:"合計所得 58万円超〜133万円以下", s:"給与収入のみ：123万円超〜201万5,999円以下（満額38万円は給与160万円まで）" },
      { l:"納税者の収入", v:"合計所得 1,000万円以下", s:"給与収入のみ：1,195万円以下" },
    ],
    amounts:[
      { c:"配偶者所得58〜68万（給与123〜133万）、納税者≦900万", a:"38万円（住民税33万円）" },
      { c:"配偶者所得68〜73万（給与133〜138万）、納税者≦900万", a:"36万円（住民税33万円）" },
      { c:"配偶者所得73〜78万（給与138〜143万）、納税者≦900万", a:"31万円（住民税31万円）" },
      { c:"配偶者所得78〜83万（給与143〜148万）、納税者≦900万", a:"26万円（住民税26万円）" },
      { c:"配偶者所得83〜88万（給与148〜153万）、納税者≦900万", a:"21万円（住民税21万円）" },
      { c:"配偶者所得88〜93万（給与153〜158万）、納税者≦900万", a:"16万円（住民税16万円）" },
      { c:"配偶者所得93〜98万（給与158〜163万）、納税者≦900万", a:"11万円（住民税11万円）" },
      { c:"配偶者所得98〜103万（給与163〜168万）、納税者≦900万", a:"6万円（住民税6万円）" },
      { c:"配偶者所得103〜133万（給与168〜201万）、納税者≦900万", a:"3万円（住民税3万円）" },
    ],
    note:"⚠️【源泉徴収との関係】配偶者の所得95万円超〜133万円以下の場合、毎月の源泉徴収計算には反映されません（年末調整のみで適用）。所得95万円以下なら源泉控除対象配偶者として毎月の源泉徴収にも反映されます。納税者の所得900万超で控除額がさらに減少し、1,000万超は適用なし。夫婦が互いに適用することは不可（どちらか一方のみ）。70歳以上の配偶者には控除額の上乗せなし（配偶者控除と異なる点）。",
  },

