      { c:"合計所得 132万超〜655万円以下", a:"88〜58万円（段階的）" },
      { c:"合計所得 655万超〜2,350万円以下", a:"58万円" },
      { c:"合計所得 2,350万円超", a:"0円（適用なし）" },
    ],
    note:"⚠️【別書類が必要】「基礎控除申告書（＝配偶者控除等申告書と兼用）」を提出しないと令和7年改正の引き上げ分が年末調整に反映されません。令和7年度改正で基礎控除が大幅に引き上げられた（旧：一律48万円）。合計所得が低いほど控除額が大きくなる逆進的な仕組み。住民税の基礎控除は43万円のまま据え置き（所得税のみ改正）。",
  },

  /* ---- 給与所得控除 ----*/
  {
    id:"kyuyo", sortIncome:9999, badge:"b-purple", badgeText:"本人",
    title:"給与所得控除",
    amountShort:"控除額：最低保障65万円〜最大195万円",
    incomeReq:"要件：給与収入がある人全員に自動適用",
    section:"self",
    matchRule:{ selfSpecial:"kyuyo" },
    conditions:[
      { l:"対象", v:"給与収入がある人全員に自動適用（申告不要）" },
      { l:"計算", v:"給与収入金額に応じて自動計算される必要経費相当の控除" },
    ],
    amounts:[
      { c:"給与収入 162.5万円以下", a:"65万円（最低保障）" },
      { c:"給与収入 162.5万超〜180万以下", a:"収入×40%−10万円" },
      { c:"給与収入 180万超〜360万以下", a:"収入×30%＋8万円" },
      { c:"給与収入 360万超〜660万以下", a:"収入×20%＋44万円" },
      { c:"給与収入 660万超〜850万以下", a:"収入×10%＋110万円" },
      { c:"給与収入 850万超", a:"195万円（上限）" },
    ],
    note:"✅【申告不要・自動適用】別途申告は不要です。令和7年改正で最低保障額が55万円→65万円に引き上げ（旧：55万円）。これにより給与収入123万円以下なら給与所得が58万円以下となり、配偶者・扶養の収入要件の判定に影響する。",
  },

  /* ---- 障害者控除（本人が障害者） ----*/
  {
    id:"disability_self", sortIncome:0, badge:"b-amber", badgeText:"本人障害",
    title:"障害者控除（本人が障害者）",
    amountShort:"控除額：27万円（一般）／40万円（特別）",
    incomeReq:"要件：収入要件なし（本人が対象の場合は所得に関わらず適用）",
    section:"self",
    matchRule:{ selfSpecial:"disability_self" },
    conditions:[
      { l:"一般障害者", v:"障害者手帳（身体・精神・療育）保持、または医師の診断書等による認定" },
      { l:"特別障害者", v:"身体障害者手帳1・2級、療育手帳A、精神保健福祉手帳1級など重度の障害" },
      { l:"収入要件", v:"本人が対象の場合：収入要件なし、無条件で適用" },
    ],
    amounts:[
      { c:"一般障害者", a:"27万円（住民税26万円）" },
      { c:"特別障害者", a:"40万円（住民税30万円）" },
    ],
    note:"扶養控除・配偶者控除・ひとり親控除・寡婦控除と重複して適用可。家族が障害者の場合は「家族の状況」の障害者控除を参照。",
  },

  /* ---- 所得金額調整控除 ----*/
  {
    id:"income_adj", sortIncome:850, badge:"b-purple", badgeText:"本人",
    title:"所得金額調整控除",
    amountShort:"控除額：最大15万円（給与収入850万円超の部分×10%）",
    incomeReq:"要件：給与収入850万円超で、①本人が特別障害者、②扶養の配偶者・親族が特別障害者、③23歳未満の扶養親族がいる、のいずれかに該当",
    section:"self",
    matchRule:{ selfSpecial:"income_adj" },
    conditions:[
      { l:"対象", v:"給与収入が850万円を超え、かつ次の①〜③のいずれかに該当する人", s:"①本人が特別障害者　②同一生計配偶者または扶養親族が特別障害者　③年齢23歳未満の扶養親族がいる" },
      { l:"給与収入", v:"850万円超（1,000万円超の場合は1,000万円として計算）" },
      { l:"控除の性質", v:"所得控除ではなく「給与所得の金額そのもの」を減額する控除（課税所得の計算前に差し引く）" },
    ],
    amounts:[
      { c:"控除額の計算式", a:"（給与収入金額 − 850万円）× 10%（1,000万円超の場合は上限1,000万円）" },
      { c:"控除額の上限", a:"15万円（給与収入1,000万円以上で上限到達）" },
      { c:"夫婦ともに該当する場合", a:"双方それぞれで適用可（扶養控除と異なり一方のみという制限なし）" },
    ],
    note:"⚠️【別書類が必要】「所得金額調整控除申告書（基礎控除申告書と兼用の書類）」を提出しないと年末調整に反映されません。給与所得と年金所得の双方がある場合の調整控除（年金等）は年末調整では対応不可のため、確定申告が必要。令和2年の給与所得控除の上限引き下げに伴う税負担増加を緩和する目的で創設。",
  },

  /* ---- 勤労学生控除 ----*/
  {
    id:"student", sortIncome:150, badge:"b-purple", badgeText:"勤労学生",
    title:"勤労学生控除",
    amountShort:"控除額：27万円（住民税26万円）",
    incomeReq:"要件：本人の所得85万円以下（給与収入のみ：150万円以下）",
    section:"self",
    matchRule:{ selfSpecial:"student" },
    conditions:[
      { l:"対象", v:"給与所得などの勤労による所得がある学生・生徒本人に適用される控除（親への控除ではない）" },
      { l:"収入要件", v:"合計所得 85万円以下（給与収入のみ：150万円以下）かつ勤労以外の所得が10万円以下" },
      { l:"学校要件", v:"学校教育法の大学・高校・専修学校、または職業訓練校の在籍者" },
    ],
    amounts:[
      { c:"所得税", a:"27万円" },
      { c:"住民税", a:"26万円" },
    ],
    note:"令和7年改正で所得要件75万円→85万円に引き上げ（給与収入換算：130万円→150万円）。令和7年改正後、所得税については基礎控除の引き上げにより給与収入160万円まで所得税が非課税となったため、所得税軽減の実益は薄い。住民税については基礎控除が48万円のまま据え置きのため、住民税軽減の効果は引き続きある。【注意】学生の年収が123万円を超えると、親の扶養控除の対象外となり、親の税負担が増加する点に注意。",
  },
];

/* ============================================================
   ここより下は編集不要です
   ============================================================
   ロジックゾーン構成:
     状態管理    : state, incomeBlocks, blockId
     所得計算    : calcDeduction / blockIncome / totalIncome
     収入ブロック: addIncomeBlock / removeIncomeBlock / clearAllIncome
                   updateBlock / setPensionAge / blockHTML
                   renderIncomeBlocks / updateIncomeResults
     クリア系    : clearAll / clearRel / clearAge / clearSelf
                   resetSpecial / resetSelfSpecial
     UI制御      : selOne / updateAgeChips / selMulti
                   onSelfChange / updateSelfNote
     表示        : matchDeduction / render / renderCard / toggle
     年齢計算    : calcAge（税法上の加齢日 = 誕生日前日）
   ============================================================ */
</script>

<div class="page-header">
  <h1>所得税・住民税 控除ガイド</h1>
  <span class="rev-tag">令和7年12月施行 改正対応</span>
  <span class="upd-tag" id="upd-label"></span>
</div>

<div class="layout">
  <div class="sidebar">

    <!-- すべてクリア -->
    <div class="sec" style="margin-bottom:12px">
      <button onclick="clearAll()" style="width:100%;padding:7px 0;border:0.5px solid var(--danger-border);border-radius:var(--radius);font-size:12px;cursor:pointer;background:transparent;color:var(--danger-text);font-weight:500;">すべてクリア</button>
    </div>

    <!-- ══ 家族の状況 ══ -->
    <div style="font-size:12px;font-weight:700;color:var(--text);letter-spacing:0.04em;margin-bottom:10px;padding:7px 10px;background:var(--info-bg);color:var(--info-text);border-radius:var(--radius);border-left:3px solid var(--info-border)">👨‍👩‍👧 家族の状況</div>

    <!-- 家族の続柄 -->
    <div class="sec">
      <div class="sec-label">続柄
        <button class="clear-btn" onclick="clearRel()">クリア</button>
      </div>
      <div class="chips" id="chips-rel">
        <button class="chip" data-val="spouse"  onclick="selOne('rel',this)">配偶者</button>
        <button class="chip" data-val="child"   onclick="selOne('rel',this)">子ども</button>
        <button class="chip" data-val="parent"  onclick="selOne('rel',this)">親・祖父母</button>
        <button class="chip" data-val="sibling" onclick="selOne('rel',this)">兄弟・姉妹</button>
        <button class="chip" data-val="other"   onclick="selOne('rel',this)">その他親族</button>
      </div>
    </div>

    <!-- 家族の年齢 -->
    <div class="sec">
      <div class="sec-label">年齢
        <button class="clear-btn" onclick="clearAge()">クリア</button>
      </div>
      <div class="chips" id="chips-age">
        <button class="chip" data-val="u16"    onclick="selOne('age',this)">15歳以下</button>
        <button class="chip" data-val="16_18"  onclick="selOne('age',this)">16〜18歳</button>
        <button class="chip" data-val="19_22"  onclick="selOne('age',this)">19〜22歳</button>
        <button class="chip" data-val="23_69"  onclick="selOne('age',this)">23〜69歳</button>
        <button class="chip" data-val="70plus" onclick="selOne('age',this)">70歳以上</button>
      </div>
    </div>

    <!-- 家族の収入 -->
    <div class="sec">
      <div class="sec-label">収入
        <button class="clear-btn" onclick="clearAllIncome()">クリア</button>
      </div>
      <div id="inc-blocks"></div>
      <button class="add-btn" onclick="addIncomeBlock()">＋ 収入を追加</button>
      <div id="total-box" style="display:none" class="total-box">
        <div class="total-label">合計所得（概算）</div>
        <div class="total-val" id="total-val">—</div>
      </div>
    </div>

    <!-- 家族の障害（任意） -->
    <!--
      【後任へ】家族チップを追加する手順:
      1. 下記 <div id="chips-special"> 内に <button> を追加
         例: <button class="chip" data-val="新キー" onclick="selMulti('fam',this)">表示名</button>
      2. DEDUCTIONS配列に matchRule:{special:"新キー"} のカードを追加
      ※ data-val と matchRule.special を必ず一致させること
    -->
    <div class="sec">
      <div class="sec-label">障害（任意・複数可）
        <button class="clear-btn" onclick="resetSpecial()">クリア</button>
      </div>
      <div class="chips" id="chips-special">
        <button class="chip" data-val="disability_general"  onclick="selMulti('fam',this)">障害あり（一般）</button>
        <button class="chip" data-val="disability_special"  onclick="selMulti('fam',this)">重度障害（特別）</button>
        <button class="chip" data-val="cohabit_disability"  onclick="selMulti('fam',this)">重度障害・同居</button>
      </div>
    </div>

    <hr class="divider">

    <!-- ══ 本人の状況 ══ -->
    <div style="font-size:12px;font-weight:700;letter-spacing:0.04em;margin-bottom:10px;padding:7px 10px;background:var(--success-bg);color:var(--success-text);border-radius:var(--radius);border-left:3px solid var(--success-border)">👤 本人の状況</div>

    <!-- 職員（本人）の所得 -->
    <div class="sec">
      <div class="sec-label">職員（本人）の合計所得
        <button class="clear-btn" onclick="clearSelf()">クリア</button>
      </div>
      <div class="inc-row">
        <label style="min-width:0;font-size:11px;color:var(--text2)">合計所得</label>
        <input type="number" id="self-income" min="0" step="1" placeholder="空欄＝1,000万円未満"
          style="width:150px;" onchange="onSelfChange(this.value)">
        <span class="unit">万円</span>
      </div>
      <div class="self-note" id="self-note">空欄の場合は1,000万円未満として判定します</div>
    </div>

    <!-- 本人の状況（任意・複数可） -->
    <!--
      【後任へ】本人チップを追加する手順:
      1. 下記 <div id="chips-self-special"> 内に <button> を追加
         例: <button class="chip" data-val="新キー" onclick="selMulti('self',this)">表示名</button>
      2. DEDUCTIONS配列に section:"self", matchRule:{selfSpecial:"新キー"} のカードを追加
      ※ data-val と matchRule.selfSpecial を必ず一致させること
    -->
    <div class="sec">
      <div class="sec-label">本人の状況（任意・複数可）
        <button class="clear-btn" onclick="resetSelfSpecial()">クリア</button>
      </div>
      <div class="chips" id="chips-self-special">
        <button class="chip" data-val="kiso"            onclick="selMulti('self',this)">基礎控除</button>
        <button class="chip" data-val="kyuyo"           onclick="selMulti('self',this)">給与所得控除</button>
        <button class="chip" data-val="disability_self" onclick="selMulti('self',this)">障害者（本人）</button>
        <button class="chip" data-val="single_parent"   onclick="selMulti('self',this)">ひとり親</button>
        <button class="chip" data-val="widow"           onclick="selMulti('self',this)">寡婦</button>
        <button class="chip" data-val="income_adj"      onclick="selMulti('self',this)">所得金額調整</button>
        <button class="chip" data-val="student"         onclick="selMulti('self',this)">勤労学生</button>
      </div>
    </div>

    <hr class="divider">

    <!-- 年齢計算ツール -->
    <div class="sec">
      <div class="sec-label">税法上の年齢を計算</div>
      <div class="age-tool">
        <div class="age-row">
          <label>生年月日</label>
          <input type="date" id="bdate" onchange="calcAge()">
        </div>
        <div class="age-row">
          <label>判定年</label>
          <input type="number" id="judge-year" min="1900" max="2100" value="2026" style="width:72px;padding:4px 7px;border:0.5px solid var(--border2);border-radius:var(--radius);font-size:12px;background:var(--bg);color:var(--text);" onchange="calcAge()">
          <span style="font-size:11px;color:var(--text2)">年 12月31日時点</span>
        </div>
        <div class="age-result" id="age-result" style="display:none"></div>
        <div class="age-note">
          ※税法上の年齢は「誕生日の前日」に加算されます（年齢計算ニ関スル法律・民法143条）。例：4月1日生まれは3月31日に年齢が上がるため、4月1日生まれと4月2日生まれで学年が変わります。また1月1日生まれは前年12月31日に加齢するため、判定日（12月31日）時点で1歳になります。所得税の年齢判定は12月31日時点で行います。
        </div>
      </div>
    </div>

  </div><!-- /sidebar -->

  <div class="main">
    <div class="results-heading">該当する控除</div>
    <div class="result-count" id="result-count"></div>
    <div id="results"><div class="guide">左の条件を選択すると、該当する控除が表示されます。</div></div>
  </div>
</div>

<script>
document.getElementById('upd-label').textContent = 'データ更新日: ' + DATA_UPDATED;

const state = {
  rel: null, age: null,
  famSpecial: new Set(),
  selfSpecial: new Set(),
  selfIncome: null,
};
let incomeBlocks = [];
let blockId = 0;

const INC_TYPES = [
  { val:'salary',   label:'給与収入' },
  { val:'pension',  label:'年金収入' },
  { val:'business', label:'事業収入' },
  { val:'other',    label:'その他収入' },
];

/* ---- 所得計算 ---- */
/**
 * 収入種別ごとの控除額を計算する
 * @param {string}  type  収入種別: salary / pension / business / other
 * @param {number}  gross 収入金額（万円）
 * @param {number}  dm    必要経費（万円）businessのみ使用
 * @param {boolean} is65  年金受給者が65歳以上か pensionのみ使用
 * @returns {number} 控除額（万円）
 */
function calcDeduction(type, gross, dm, is65) {
  if (type==='salary') {
    if (gross<=162.5) return 65;
    if (gross<=180)   return gross*0.4-10;
    if (gross<=360)   return gross*0.3+8;
    if (gross<=660)   return gross*0.2+44;
    if (gross<=850)   return gross*0.1+110;
    return 195;
  }
  if (type==='pension') {
    if (is65) {
      if (gross<=330)  return 110;
      if (gross<=410)  return gross*0.25+27.5;
      if (gross<=770)  return gross*0.15+68.5;
      if (gross<=1000) return gross*0.05+145.5;
      return 195.5;
    } else {
      if (gross<=130)  return 60;
      if (gross<=410)  return gross*0.25+27.5;
      if (gross<=770)  return gross*0.15+68.5;
      if (gross<=1000) return gross*0.05+145.5;
      return 195.5;
    }
  }
  if (type==='business') return isNaN(dm)?0:dm;
  return 0;
}
function blockIncome(b) {
  const gross = parseFloat(b.gross)||0;
  const dm    = parseFloat(b.deductManual)||0;
  // 年金収入は個別ブロックのis65フラグを使用、その他は年齢チップから判断
  const is65 = b.type==='pension' ? (b.is65===true) : (state.age==='70plus');
  return Math.max(0, gross - calcDeduction(b.type, gross, dm, is65));
}
function totalIncome() {
  if (!incomeBlocks.length) return null;
  if (!incomeBlocks.some(b=>b.gross!==''&&!isNaN(parseFloat(b.gross)))) return null;
  return incomeBlocks.reduce((s,b)=>s+blockIncome(b), 0);
}

/* ---- 収入ブロック ---- */
function addIncomeBlock() {
  incomeBlocks.push({ id:++blockId, type:'salary', gross:'', deductManual:'', is65:false });
  renderIncomeBlocks(); render();
}
function setPensionAge(id, is65) {
  const b = incomeBlocks.find(b=>b.id===id);
  if (b) b.is65 = is65;
  renderIncomeBlocks(); render();
}
function removeIncomeBlock(id) {
  incomeBlocks = incomeBlocks.filter(b=>b.id!==id);
  renderIncomeBlocks(); render();
}
function clearAllIncome() {
  incomeBlocks = [{ id:++blockId, type:'salary', gross:'', deductManual:'', is65:false }];
  renderIncomeBlocks(); render();
}
function updateBlock(id, field, val) {
  const b = incomeBlocks.find(b=>b.id===id);
  if (b) {
    b[field] = val;
    if (field==='type') b.is65 = false; // 収入種別変更時はis65をリセット
  }
  renderIncomeBlocks(); render();
}

function blockHTML(b) {
  const is65    = state.age==='70plus';
  const typeOpts = INC_TYPES.map(t=>`<option value="${t.val}"${t.val===b.type?' selected':''}>${t.label}</option>`).join('');
  const rowLabel = b.type==='business'?'収入（売上）':b.type==='other'?'収入または所得':(INC_TYPES.find(t=>t.val===b.type)?.label||'');
  let hint='', extraRow='';
  if      (b.type==='salary')   hint='給与所得控除が自動計算されます（最低保障65万円）';
  else if (b.type==='pension') {
    const pensionIs65 = b.is65 === true;
    extraRow = `<div style="margin-top:6px;display:flex;gap:5px;flex-wrap:wrap;align-items:center">
      <span style="font-size:11px;color:var(--text2)">年齢：</span>
      <button onclick="setPensionAge(${b.id},false)" style="padding:3px 10px;border:0.5px solid ${!pensionIs65?'var(--info-border)':'var(--border2)'};border-radius:99px;font-size:11px;cursor:pointer;background:${!pensionIs65?'var(--info-bg)':'transparent'};color:${!pensionIs65?'var(--info-text)':'var(--text2)'}">65歳未満</button>
      <button onclick="setPensionAge(${b.id},true)"  style="padding:3px 10px;border:0.5px solid ${pensionIs65?'var(--info-border)':'var(--border2)'};border-radius:99px;font-size:11px;cursor:pointer;background:${pensionIs65?'var(--info-bg)':'transparent'};color:${pensionIs65?'var(--info-text)':'var(--text2)'}">65歳以上</button>
    </div>`;
    hint = pensionIs65
      ? '65歳以上：公的年金等控除が自動計算されます（最低保障110万円 → 年金収入168万円以下で所得58万円以下）'
      : '65歳未満：公的年金等控除が自動計算されます（最低保障60万円 → 年金収入118万円以下で所得58万円以下）';
  }
  else if (b.type==='business') {
    extraRow=`<div class="inc-row" style="margin-top:5px"><label>必要経費・控除額</label><input type="number" id="dm-${b.id}" min="0" step="0.1" placeholder="例：80" value="${b.deductManual}" onchange="updateBlock(${b.id},'deductManual',this.value)"><span class="unit">万円</span></div>`;
    hint='事業所得＝収入－必要経費。青色申告控除（最大65万円）も含めて入力してください。';
  }
  else if (b.type==='other') hint='一時所得・雑所得など。控除がない場合は収入金額をそのまま所得として入力してください。';
  return `<div class="inc-block" id="blk-${b.id}">
    <div class="inc-head">
      <select onchange="updateBlock(${b.id},'type',this.value)">${typeOpts}</select>
      <button class="remove-btn" onclick="removeIncomeBlock(${b.id})">削除</button>
    </div>
    <div class="inc-row">
      <label>${rowLabel}</label>
      <input type="number" id="gr-${b.id}" min="0" step="0.1" placeholder="例：120" value="${b.gross}" onchange="updateBlock(${b.id},'gross',this.value)">
      <span class="unit">万円</span>
    </div>
    ${extraRow}
    ${hint?`<div class="inc-hint">${hint}</div>`:''}
    <div class="inc-result" id="res-${b.id}" style="display:none"></div>
  </div>`;
}

function renderIncomeBlocks() {
  document.getElementById('inc-blocks').innerHTML = incomeBlocks.map(blockHTML).join('');
  updateIncomeResults();
}

function updateIncomeResults() {
  incomeBlocks.forEach(b=>{
    const el = document.getElementById('res-'+b.id);
    if (!el) return;
    const gross = parseFloat(b.gross)||0;
    const is65  = b.type==='pension' ? (b.is65===true) : (state.age==='70plus');
    const dm    = parseFloat(b.deductManual)||0;
    const deduct = calcDeduction(b.type, gross, dm, is65);
    const income = Math.max(0, gross-deduct);
    const show = b.gross!==''&&!isNaN(parseFloat(b.gross));
    if (show) {
      el.style.display='';
      el.innerHTML=`所得（概算）：<span>${Math.round(income*10)/10} 万円</span>${b.type==='other'?'（入力値をそのまま使用）':`（控除 ${Math.round(deduct*10)/10} 万円）`}`;
    } else {
      el.style.display='none'; el.innerHTML='';
    }
  });
  const tot = totalIncome();
  const tb = document.getElementById('total-box');
  const tv = document.getElementById('total-val');
  if (tot!==null) {
    tb.style.display='';
    const r = Math.round(tot*10)/10;
    const ok = r<=58;
    tv.className = 'total-val'+(ok?' ok':' ng');
    tv.textContent = `${r} 万円　${ok?'→ 58万円以下（控除対象の所得範囲内）':'→ 58万円超（一般扶養・配偶者控除の対象外）'}`;
  } else {
    tb.style.display='none';
  }
}

/* ---- 全クリア ---- */
function clearAll() {
  // 本人所得クリア
  state.selfIncome = null;
  document.getElementById('self-income').value = '';

  // 本人状況チップクリア
  state.selfSpecial.clear();
  document.querySelectorAll('#chips-self-special .chip').forEach(c=>c.classList.remove('sel'));

  // 続柄クリア
  state.rel = null;
  document.querySelectorAll('#chips-rel .chip').forEach(c=>c.classList.remove('sel'));

  // 年齢クリア
  state.age = null;
  document.querySelectorAll('#chips-age .chip').forEach(c=>{ c.classList.remove('sel','dim'); });

  // 収入クリア（給与1行に戻す）
  incomeBlocks = [{ id:++blockId, type:'salary', gross:'', deductManual:'', is65:false }];

  // 家族特別事情クリア
  state.famSpecial.clear();
  document.querySelectorAll('#chips-special .chip').forEach(c=>c.classList.remove('sel'));

  // 年齢計算ツールクリア
  const bdateEl = document.getElementById('bdate');
  if (bdateEl) bdateEl.value = '';
  const ageEl = document.getElementById('age-result');
  if (ageEl) ageEl.style.display = 'none';

  updateSelfNote();
  renderIncomeBlocks();
  render();
}

function clearRel() {
  state.rel = null;
  document.querySelectorAll('#chips-rel .chip').forEach(c=>c.classList.remove('sel'));
  // 配偶者解除時は年齢チップのdimも解除
  document.querySelectorAll('#chips-age .chip').forEach(c=>c.classList.remove('dim'));
  renderIncomeBlocks(); render();
}
function clearAge() {
  state.age = null;
  document.querySelectorAll('#chips-age .chip').forEach(c=>c.classList.remove('sel'));
  renderIncomeBlocks(); render();
}

/* ---- 本人所得 ---- */
function onSelfChange(val) {
  state.selfIncome = val===''?null:parseFloat(val);
  updateSelfNote(); render();
}
function clearSelf() {
  state.selfIncome = null;
  document.getElementById('self-income').value='';
  updateSelfNote(); render();
}
function updateSelfNote() {
  const el = document.getElementById('self-note');
  const v = state.selfIncome;
  if (v===null) { el.style.color='var(--text3)'; el.textContent='空欄の場合は1,000万円未満として判定します'; return; }
  const notes = [];
  if (v>2350) notes.push('2,350万円超：基礎控除も適用不可');
  if (v>1000) notes.push('1,000万円超：配偶者控除・配偶者特別控除は適用不可');
  else if (v>950) notes.push('950万円超〜1,000万円以下：配偶者控除の控除額が減額（最大13万円）');
  else if (v>900) notes.push('900万円超〜950万円以下：配偶者控除の控除額が減額（最大26万円）');
  if (v>900) notes.push('900万円超：源泉控除対象配偶者は対象外（源泉徴収計算に反映されない）');
  if (v>500) notes.push('500万円超：ひとり親控除・寡婦控除は適用不可');
  if (v>85)  notes.push('85万円超：勤労学生控除は適用不可');
  if (notes.length===0) {
    el.style.color='var(--success-text)'; el.textContent='すべての控除の所得要件を満たしています';
  } else {
    el.style.color='var(--warning-text)'; el.textContent=notes.join('　／　');
  }
}

/* ---- 選択操作 ---- */
function selOne(type, el) {
  document.querySelectorAll('#chips-'+type+' .chip').forEach(c=>c.classList.remove('sel'));
  if (state[type]===el.dataset.val) state[type]=null;
  else { el.classList.add('sel'); state[type]=el.dataset.val; }
  updateAgeChips(); renderIncomeBlocks(); render();
}
function updateAgeChips() {
  const ageChips = document.querySelectorAll('#chips-age .chip');
  if (state.rel==='spouse') {
    ageChips.forEach(c=>{ c.classList.add('dim'); c.classList.remove('sel'); });
    state.age=null;
  } else {
    ageChips.forEach(c=>c.classList.remove('dim'));
  }
}
function selMulti(target, el) {
  const v = el.dataset.val;
  const set = target==='self' ? state.selfSpecial : state.famSpecial;
  if (set.has(v)) { set.delete(v); el.classList.remove('sel'); }
  else { set.add(v); el.classList.add('sel'); }
  render();
}
function resetSpecial() {
  state.famSpecial.clear();
  document.querySelectorAll('#chips-special .chip').forEach(c=>c.classList.remove('sel'));
  render();
}
function resetSelfSpecial() {
  state.selfSpecial.clear();
  document.querySelectorAll('#chips-self-special .chip').forEach(c=>c.classList.remove('sel'));
  render();
}

/* ---- matchDeduction ---- */
/**
 * DEDUCTIONSの1件が現在の選択状態にマッチするか判定する
 * @param {Object}      d   DEDUCTIONSの1要素
 * @param {number|null} tot 家族の合計所得（万円）。未入力はnull
 * @returns {boolean}
 * [特例] 配偶者選択+収入未入力 → spouse_ctrl/spouse_special を両方表示
 * [特例] 19〜22歳選択+収入未入力 → dep_specific/dep_tokutei を両方表示
 */
function matchDeduction(d, tot) {
  const r = d.matchRule;
  if (!r) return false;

  // 本人の状況カード（selfSpecial）の判定
  if (r.selfSpecial) {
    return state.selfSpecial.has(r.selfSpecial);
  }

  // 家族の状況カードの判定
  if (r.rel    && state.rel!==r.rel)                              return false;
  if (r.relNot && state.rel===r.relNot)                          return false;
  if (r.ageIn  && (!state.age||!r.ageIn.includes(state.age)))   return false;
  if (r.special && !state.famSpecial.has(r.special))             return false;
  if (r.specialNot) { for (const s of r.specialNot) { if (state.famSpecial.has(s)) return false; } }

  // 配偶者選択時・収入未入力の場合は配偶者控除・配偶者特別控除の両方を表示
  const isSpouseNoIncome = (state.rel==='spouse' && tot===null);
  if (isSpouseNoIncome && r.rel==='spouse') return true;

  // 19〜22歳選択時・収入未入力の場合は特定扶養控除・特定親族特別控除の両方を表示
  const is1922NoIncome = (state.age==='19_22' && tot===null && state.rel!=='spouse');
  if (is1922NoIncome && r.ageIn && r.ageIn.includes('19_22')) return true;

  if (r.incomeMax!==undefined) {
    if (tot===null) { if (r.incomeMin!==undefined) return false; }
    else if (tot>r.incomeMax) return false;
  }
  if (r.incomeMin!==undefined) { if (tot===null||tot<=r.incomeMin) return false; }
  return true;
}

/* ---- render ---- */
/**
 * 選択状態を元に結果カードを描画する
 * 描画順: famMatched（家族の状況）→ selfMatched（本人の状況）
 * 各セクション内は sortIncome の昇順でソート
 */
function render() {
  const tot  = totalIncome();
  const self = state.selfIncome;
  const famHasFilter = state.rel||state.age||state.famSpecial.size>0||incomeBlocks.some(b=>b.gross!==''&&!isNaN(parseFloat(b.gross)));
  const selfHasFilter = state.selfSpecial.size>0;
  const hasFilter = famHasFilter || selfHasFilter;

  const countEl   = document.getElementById('result-count');
  const container = document.getElementById('results');

  // 家族の状況カード（section:'self'を持たないもの）
  const famMatched = DEDUCTIONS.filter(d=>{
    if (d.section==='self') return false; // 本人カードは除外
    if (!matchDeduction(d, tot)) return false;
    if (self!==null) {
      // 配偶者控除・配偶者特別控除：職員の所得1,000万円超で除外
      if (self>1000 && (d.id==='spouse_ctrl'||d.id==='spouse_special')) return false;
      // 源泉控除対象配偶者：職員の所得900万円超で除外（源泉控除対象配偶者の要件）
      if (self>900 && d.id==='spouse_gensen') return false;
    }
    return true;
  });
  // 本人の状況カード（section:'self'を持つもの）
  const selfMatched = DEDUCTIONS.filter(d=>{
    if (d.section!=='self') return false;
    if (!matchDeduction(d, tot)) return false;
    // 本人所得による除外
    if (self!==null) {
      // 基礎控除：合計所得2,350万円超で適用なし
      if (self>2350 && d.id==='kiso') return false;
      // 配偶者控除・配偶者特別控除：1,000万円超で適用なし（家族側で制御済みだが念のため）
      // ひとり親・寡婦：500万円超で適用なし
      if (self>500 && (d.id==='single_parent'||d.id==='widow')) return false;
      // 勤労学生：本人の合計所得85万円超で適用なし
      if (self>85 && d.id==='student') return false;
    }
    return true;
  });
  // sortIncomeで昇順ソート（収入要件が少ない順）
  famMatched.sort((a,b) => (a.sortIncome??9999) - (b.sortIncome??9999));
  selfMatched.sort((a,b) => (a.sortIncome??9999) - (b.sortIncome??9999));
  const matched = [...famMatched, ...selfMatched];

  if (!hasFilter) {
    countEl.textContent='';
    container.innerHTML='<div class="guide">左の条件を選択すると、該当する控除が表示されます。</div>';
    return;
  }

  // 案内メッセージ
  if (famHasFilter && state.rel && state.rel!=='spouse' && !state.age && state.famSpecial.size===0 && !incomeBlocks.some(b=>b.gross!==''&&!isNaN(parseFloat(b.gross)))) {
    if (!selfHasFilter) {
      countEl.textContent='';
      container.innerHTML='<div class="guide">次に「家族の年齢」を選択してください。</div>';
      return;
    }
  }
  if (self!==null && self>1000 && state.rel==='spouse') {
    countEl.textContent='';
    container.innerHTML='<div class="empty">職員の合計所得が1,000万円超のため、<br>配偶者控除・配偶者特別控除は適用対象外です。<br><br>家族に障害がある場合は「障害」チップから選択してください。<br>本人の控除（基礎控除など）は「本人の状況」から確認できます。</div>';
    return;
  }
  if (state.rel==='spouse' && tot!==null && tot>133) {
    countEl.textContent='';
    container.innerHTML='<div class="empty">配偶者の合計所得が133万円超（給与収入201.6万円超）のため、<br>配偶者控除・配偶者特別控除ともに適用対象外です。<br><br>特別事情（障害・ひとり親など）がある場合は下のチップから選択してください。</div>';
    return;
  }

  const totalCount = famMatched.length + selfMatched.length;
  countEl.textContent = totalCount>0?`${totalCount}件の控除が該当します`:'';
  if (!totalCount) {
    container.innerHTML='<div class="empty">選択した条件では該当する控除がありません。<br>条件を変えてお試しください。</div>';
    return;
  }

  const renderCard = (d, tot) => {
    // 常時表示エリアの生成
    const isSpouseNoIncome = (state.rel==='spouse' && tot===null);
    let incomeReqText = d.incomeReq||'';
    // 配偶者収入未入力時は「収入を入力すると自動で絞り込みます」を追記
    let spouseHint = '';
    const is1922NoIncome = (state.age==='19_22' && tot===null && state.rel!=='spouse');
    if (isSpouseNoIncome && (d.id==='spouse_ctrl'||d.id==='spouse_special')) {
      spouseHint = `<span style="font-size:11px;color:var(--warning-text);margin-top:2px;display:inline-block">収入を入力すると自動で絞り込みます</span>`;
    } else if (is1922NoIncome && (d.id==='dep_specific'||d.id==='dep_tokutei')) {
      spouseHint = `<span style="font-size:11px;color:var(--warning-text);margin-top:2px;display:inline-block">収入を入力すると自動で絞り込みます</span>`;
    }
    const visibleHTML = `
      <div class="card-visible" style="flex-direction:column;align-items:flex-start;gap:2px">
        ${incomeReqText ? `<span class="cv-amount" style="font-size:12px;font-weight:500;color:var(--text)">${incomeReqText}</span>` : ''}
        ${d.amountShort ? `<span style="font-size:11px;color:var(--text3)">${d.amountShort}</span>` : ''}
        ${spouseHint}
      </div>`;

    return `<div class="card" id="dc-${d.id}" onclick="toggle('${d.id}')">
      <div class="card-head">
        <span class="badge ${d.badge}">${d.badgeText}</span>
        <div class="card-summary">
          <div class="card-title">
            ${d.title}${d.isNew?'<span class="new-tag">令和7年新設</span>':''}
            ${d.note&&d.note.includes('⚠️') ? '<span style="margin-left:8px;font-size:11px;font-weight:500;background:var(--warning-bg);color:var(--warning-text);border-radius:4px;padding:1px 6px;vertical-align:middle;white-space:nowrap">⚠️ 要年末調整申告</span>' : ''}
            ${d.note&&d.note.startsWith('✅') ? '<span style="margin-left:8px;font-size:11px;font-weight:500;background:var(--success-bg);color:var(--success-text);border-radius:4px;padding:1px 6px;vertical-align:middle;white-space:nowrap">✅ 申告不要</span>' : ''}
          </div>
          ${visibleHTML}
        </div>
        <span class="chevron">▼</span>
      </div>
      <div class="detail">
        <div style="margin-bottom:8px">
          ${(d.conditions||[]).map(c=>`<div class="cond-row"><span class="cond-lbl">${c.l}</span><div><span class="cond-val">${c.v}</span>${c.s?`<div class="cond-sub">└ ${c.s}</div>`:''}</div></div>`).join('')}
        </div>
        <div class="amt-box">
          <div class="amt-title">控除額（所得税 / 住民税）</div>
          <table class="amt-table">${(d.amounts||[]).map(a=>`<tr><th>${a.c}</th><td>${a.a}</td></tr>`).join('')}</table>
        </div>
        ${d.note?`<p class="note"><b>注意点：</b>${d.note}</p>`:''}
      </div>
    </div>`;
  };

  // セクション見出しスタイル
  const secHead = (label, count, style) =>
    `<div style="font-size:12px;font-weight:700;letter-spacing:0.04em;margin:14px 0 8px;padding:6px 10px;border-radius:var(--radius);${style}">${label}（${count}件）</div>`;

  let html = '';
  if (famMatched.length > 0) {
    html += secHead('👨‍👩‍👧 家族の状況', famMatched.length, 'background:var(--info-bg);color:var(--info-text);border-left:3px solid var(--info-border)');
    html += famMatched.map(d => renderCard(d, tot)).join('');
  }
  if (selfMatched.length > 0) {
    html += secHead('👤 本人の状況', selfMatched.length, 'background:var(--success-bg);color:var(--success-text);border-left:3px solid var(--success-border)');
    html += selfMatched.map(d => renderCard(d, tot)).join('');
  }
  container.innerHTML = html;
}

function toggle(id) { document.getElementById('dc-'+id)?.classList.toggle('open'); }

/* ---- 年齢計算 ---- */
/**
 * 税法上の年齢を計算する（年齢計算ニ関スル法律・民法143条）
 *
 * [原理]
 *   税法上の年齢 = 「判定日の翌日（judgeYear+1年1月1日）時点での通常の満年齢」
 *   これは「N歳になる日 = 誕生日の前日」という税法のルールと等価。
 *
 *   例） 1/1生まれ → 加齢日=前年12/31 → 判定日12/31に加齢済み
 *        = 翌年1/1時点の満年齢と一致
 *   例） 1/2生まれ → 加齢日=当年1/1  → 判定日12/31はまだ加齢前
 *        = 翌年1/1時点の満年齢と一致
 *
 * [実装]
 *   baseYear = judgeYear + 1
 *   age = baseYear - bYear
 *   誕生日(月/日)が1/1より後（= 1/2以降）なら age--
 *   ※ bMonth > 0 || bDay > 1 のとき age--
 */
function calcAge() {
  const val = document.getElementById('bdate').value;
  const el  = document.getElementById('age-result');
  if (!val) { el.style.display='none'; return; }

  const parts = val.split('-').map(Number);
  const bYear = parts[0], bMonth = parts[1] - 1, bDay = parts[2]; // bMonth: 0-indexed

  // 判定年：入力欄の値を使用（未入力・不正値は現在の年）
  const judgeYearInput = parseInt(document.getElementById('judge-year').value, 10);
  const judgeYear = (isNaN(judgeYearInput) || judgeYearInput < 1 || judgeYearInput > 9999)
    ? new Date().getFullYear()
    : judgeYearInput;

  // 未誕生チェック：生まれた年が判定年より後
  if (bYear > judgeYear) {
    el.style.display='';
    el.innerHTML = '<strong>' + judgeYear + '年12月31日時点では未誕生です</strong>';
    return;
  }
  // 同年生まれで1/2以降かつ判定日より後（12/31より後はない。12/31自体は当日0歳）
  // → 実際には bYear=judgeYear かつ bMonth>11 は存在しないので不要だが念のため
  if (bYear === judgeYear && (bMonth > 11 || (bMonth === 11 && bDay === 31))) {
    // 12/31生まれは当日0歳（加齢日12/30なので判定日12/31時点で0歳）
    // → このケースはbelow通常計算で正しく処理される（結果0歳）
  }

  // 税法上の年齢 = (judgeYear+1) - bYear、誕生日が1/2以降なら -1
  let age = (judgeYear + 1) - bYear;
  if (bMonth > 0 || bDay > 1) age--;

  // 年齢グループ判定
  const groups = [];
  if (age <= 15)  groups.push('15歳以下（年少扶養親族）');
  if (age >= 16 && age <= 18) groups.push('16〜18歳（一般扶養控除の対象）');
  if (age >= 19 && age <= 22) groups.push('19〜22歳（特定扶養親族・特定親族特別控除の対象）');
  if (age >= 23 && age <= 69) groups.push('23〜69歳（一般扶養控除の対象）');
  if (age >= 65)  groups.push('65歳以上（年金の公的年金等控除：最低保障110万円）');
  if (age >= 70)  groups.push('70歳以上（老人扶養親族・老人控除対象配偶者の対象）');

  el.style.display='';
  el.innerHTML = '<strong>' + judgeYear + '年12月31日時点で ' + age + ' 歳</strong>'
    + (groups.length > 0 ? '<br><span style="font-size:10px;color:var(--text2)">' + groups.join('、') + '</span>' : '');
}

/* ---- 初期化 ---- */
incomeBlocks.push({ id:++blockId, type:'salary', gross:'', deductManual:'', is65:false });
renderIncomeBlocks();
render();
</script>
</body>
</html>
